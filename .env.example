# ─── MODE ───────────────────────────────────────────────────────────────────
APP_ENV=development         # development | paper | live
LOG_LEVEL=INFO

# ─── DATABASE (Supabase / PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/swarm_trading
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── BROKERS ─────────────────────────────────────────────────────────────────
# Interactive Brokers
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497=paper | 7496=live
IBKR_CLIENT_ID=1

# MetaTrader 5
MT5_LOGIN=12345678
MT5_PASSWORD=your-password
MT5_SERVER=ICMarkets-Demo

# ─── DATA FEEDS ──────────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-key
YFINANCE_ENABLED=true

# ─── NEWS ────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
FOREX_FACTORY_ENABLED=true

# ─── TELEGRAM ALERTS ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ─── SWARM CONFIG ─────────────────────────────────────────────────────────────
SWARM_TOTAL_CAPITAL_USD=100.0
SWARM_AGENT_COUNT=100
SWARM_CAPITAL_PER_AGENT=1.0
SWARM_TARGET_MULTIPLIER=10.0   # 1 USD → 10 USD per agent

# ─── RISK LIMITS (FTMO-style) ─────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=0.05      # 5% daily drawdown limit
RISK_MAX_TOTAL_LOSS_PCT=0.10      # 10% total drawdown limit
RISK_MAX_AGENTS_PER_SYMBOL=10     # max concurrent agents per symbol
RISK_NEWS_BLACKOUT_MIN=5          # minutes to block before/after high-impact news

# ─── DASHBOARD ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
