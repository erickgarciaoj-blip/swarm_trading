# ─── MODE ───────────────────────────────────────────────────────────────────
APP_ENV=development         # development | paper | live — "paper"/"live" require
                            # DATABASE_URL to be Postgres (core/config.py fails
                            # fast at startup on sqlite:// otherwise)
LOG_LEVEL=INFO              # loguru level: DEBUG | INFO | WARNING | ERROR

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL is the real runtime database — required whenever APP_ENV is
# "paper" or "live" (core/config.py fails fast at startup otherwise).
# Schema is owned exclusively by Alembic (`alembic upgrade head`); the app
# never runs CREATE TABLE itself. See docs/architecture/adr/0008.
#
# With docker-compose.yml's own "postgres" service:
DATABASE_URL=postgresql+asyncpg://swarm:changeme@postgres:5432/swarm_trading
# Local dev outside Docker, pointing at Postgres on localhost instead:
#   DATABASE_URL=postgresql+asyncpg://swarm:changeme@localhost:5432/swarm_trading
#
# SQLite (sqlite+aiosqlite:///./swarm_trading.db, core/config.py's default)
# is ONLY for APP_ENV=development and for tests/unit/* — it is never a
# production-equivalent substitute for Postgres. Postgres-specific behavior
# (real upserts, concurrent writes, Alembic-managed schema) is exercised by
# tests/integration/* against a real postgres:16, never simulated with SQLite.

# Read into settings but not currently referenced by any app code (no
# Supabase client is constructed anywhere yet). Leave blank unless/until a
# feature actually starts using it — see requirements.txt's "don't pin what
# nothing imports yet" note for the same reasoning applied to the package.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ─── REDIS ───────────────────────────────────────────────────────────────────
# Read into settings but not currently referenced by any app code either —
# provisioned in docker-compose.yml ("redis" service, ephemeral, no volume)
# ahead of Fase 5 putting it behind CachePort/PubSubPort protocols (see
# ARCHITECTURE_REVIEW.md). Hostname "redis" resolves on swarm_net; adjust to
# localhost for a local process outside Docker.
REDIS_URL=redis://redis:6379/0

# ─── BROKERS ─────────────────────────────────────────────────────────────────
# Interactive Brokers (brokers/ibkr) — only read when main.py wires up the
# IBKR adapter; irrelevant to the MT5 adapter and vice versa.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497=paper | 7496=live
IBKR_CLIENT_ID=1           # must be unique per concurrent IBKR API connection

# MetaTrader 5 (brokers/mt5)
MT5_LOGIN=12345678
MT5_PASSWORD=your-password
MT5_SERVER=ICMarkets-Demo

# ─── DATA FEEDS ──────────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-key   # data/feeds — leave blank to fall back to yfinance only
YFINANCE_ENABLED=true              # data/feeds/market_feed — set false to disable the free/unauthenticated feed

# ─── NEWS ────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key         # data/news — leave blank to disable NewsAPI-sourced headlines
FOREX_FACTORY_ENABLED=true           # data/news — economic calendar scrape used by RiskEngine's news blackout

# ─── TELEGRAM ALERTS ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token   # leave both blank to disable Telegram alerting entirely
TELEGRAM_CHAT_ID=your-chat-id

# ─── POSTGRES (used by docker-compose.yml's "postgres" service) ──────────────
POSTGRES_DB=swarm_trading
POSTGRES_USER=swarm
POSTGRES_PASSWORD=changeme   # required — compose fails to start rather than default to a blank password

# ─── SWARM CONFIG ─────────────────────────────────────────────────────────────
SWARM_TOTAL_CAPITAL_USD=100000.0
SWARM_AGENT_COUNT=100
SWARM_CAPITAL_PER_AGENT=1000.0
SWARM_TARGET_MULTIPLIER=10.0   # 1000 USD → 10000 USD per agent

# ─── RISK LIMITS (FTMO-style) ─────────────────────────────────────────────────
# Both loss limits are fractions (0.15 == 15%), not raw 0-100 percentages —
# matching every other RISK_*_PCT variable below. Both are enforced by
# default, no opt-in flag (see docs/architecture/adr/0010-daily-and-total-loss-halt.md).
# RISK_MAX_DAILY_LOSS_PCT must not exceed RISK_MAX_TOTAL_LOSS_PCT (validated
# at startup — core/config.py raises if violated).
RISK_MAX_DAILY_LOSS_PCT=0.15      # 15% daily loss halt, resets at UTC day rollover
RISK_MAX_TOTAL_LOSS_PCT=0.30      # 30% total loss halt, requires admin resume_swarm to clear
RISK_MAX_AGENTS_PER_SYMBOL=10     # max concurrent agents per symbol
RISK_NEWS_BLACKOUT_MIN=5          # minutes to block before/after high-impact news
RISK_MIN_ENTRY_PCT=0.03           # min entry size, 3% of agent equity
RISK_MAX_ENTRY_PCT=0.15           # max entry size, 15% of agent equity

# ─── DASHBOARD ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0   # bind address inside the container; host exposure is controlled by docker-compose.yml's "ports:", not this value
DASHBOARD_PORT=8000
